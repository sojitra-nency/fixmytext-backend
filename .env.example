# Backend environment variables
# Copy this file to .env (git-ignored) and adjust values as needed.

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Groq API key for AI-powered hashtag generation (free at console.groq.com)
GROQ_API_KEY=

# Auth / JWT — REQUIRED, no default. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Razorpay ──────────────────────────────────────────────────────────
# Get keys from https://dashboard.razorpay.com/app/keys
# Use rzp_test_ keys for development
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Webhook secret — set up at https://dashboard.razorpay.com/app/webhooks
# Endpoint URL: https://yourdomain.com/api/v1/subscription/webhook
# Events: payment.captured, subscription.charged, subscription.cancelled, subscription.halted
RAZORPAY_WEBHOOK_SECRET=

# Free tier limits
FREE_USES_PER_TOOL_PER_DAY=3
DAILY_LOGIN_BONUS=1

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Redis (optional — for distributed rate limiting; leave empty for in-memory)
REDIS_URL=redis://redis-service:6379/0

# Database — REQUIRED, no default.
# Use localhost for local dev, db-service for Docker
DATABASE_URL=postgresql+asyncpg://fixmytext:fixmytext_dev@db-service:5432/fixmytext

# PostgreSQL password (must match DATABASE_URL and docker-compose.yml)
POSTGRES_PASSWORD=fixmytext_dev
